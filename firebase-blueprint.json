{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "User profile and statistics",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "bioCoins": { "type": "integer" },
        "stepsToday": { "type": "integer" },
        "stepsGoal": { "type": "integer" },
        "completedModules": { "type": "integer" },
        "energyBurnKcal": { "type": "integer" },
        "lastSync": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email"]
    },
    "logs": {
      "title": "Activity Log",
      "description": "Log of user activities and rewards",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "warning", "error", "success"] },
        "reward": { "type": "integer" }
      },
      "required": ["uid", "timestamp", "message", "type"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "Individual user profile document"
    },
    "/logs/{logId}": {
      "schema": "logs",
      "description": "Individual log entry document"
    }
  }
}
